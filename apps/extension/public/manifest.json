{
  "manifest_version": 3,
  "name": "RecallTabs",
  "version": "0.1.0",

  "permissions": [
    "tabs",
    "storage"
  ],

  "host_permissions": [
    "http://localhost:8000/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "index.html"
  }
}